<div class="text-center py-12">
  <h1 class="text-4xl font-bold mb-4">Welcome to ScalingDoodle</h1>
  <p class="text-lg text-base-content/70 mb-8">
    A modern web application built with Phoenix and Ash Framework.
  </p>

  <%= if @current_user do %>
    <p class="text-base-content/60">
      You are signed in as <strong>{@current_user.email}</strong>
    </p>
  <% else %>
    <a href={~p"/sign-in"} class="btn btn-primary btn-lg">
      Get Started
    </a>
  <% end %>
</div>
